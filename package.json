{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "name": "aitehub-gadget",
    "version": "1.0.0",
    "description": "Aitehub_Tools - Aitehub Gadget",
    "main": "electron/main.cjs",
    "author": "Gordon",
    "scripts": {
        "clean": "rimraf dist",
        "dev": "vite",
        "build": "npm run clean && vite build",
        "electron:dev": "electron electron/main.cjs",
        "electron:build": "npm run clean && npm run build && electron-builder",
        "serve": "php artisan serve --port=8085"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.4",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "rimraf": "^6.1.3",
        "sass-embedded": "^1.97.3",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@pdf-lib/fontkit": "^1.0.0",
        "adm-zip": "^0.5.16",
        "cheerio": "^1.2.0",
        "crypto-js": "^4.2.0",
        "electron-is-dev": "^3.0.1",
        "element-plus": "^2.13.3",
        "epubjs": "^0.3.93",
        "idb-keyval": "^6.2.2",
        "jsdom": "^28.1.0",
        "pdf-lib": "^1.17.1"
    },
    "build": {
        "appId": "com.gordon.gedget",
        "productName": "Aitehub_Tools",
        "compression": "maximum",
        "asar": true,
        "asarUnpack": [
            "**/*"
        ],
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron/**/*",
            "app/**/*",
            "bootstrap/**/*",
            "config/**/*",
            "database/**/*",
            "public/**/*",
            "resources/**/*",
            "routes/**/*",
            "storage/**/*",
            "vendor/**/*",
            "artisan",
            "composer.json",
            ".env"
        ],
        "extraResources": [
            {
                "from": "php",
                "to": "php",
                "filter": [
                    "**/*"
                ]
            },
            {
                "from": "public",
                "to": "public",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "npmRebuild": false,
        "nodeGypRebuild": false,
        "win": {
            "icon": "resources/img/logo.ico",
            "target": [
                "portable",
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "signAndEditExecutable": false,
            "forceCodeSigning": false,
            "verifyUpdateCodeSignature": false
        },
        "linux": {
            "icon": "resources/img/logo.png"
        },
        "mac": {
            "icon": "resources/img/logo.icns"
        },
        "nsis": {
            "installerIcon": "resources/img/logo.ico",
            "uninstallerIcon": "resources/img/logo.ico",
            "oneClick": false,
            "perMachine": false,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true
        }
    }
}
